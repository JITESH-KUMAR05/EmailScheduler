# === DATABASE ===
# Azure PostgreSQL
DATABASE_URL=postgresql://pgadmin:PASSWORD@reachinbox-db.postgres.database.azure.com:5432/reachinbox?sslmode=require
# Local Docker
# DATABASE_URL=postgresql://postgres:password@localhost:5433/reachinbox

# === REDIS ===
# Azure Cache for Redis (Canada Central) - uses port 10000 with TLS
REDIS_HOST=reachinbox-redis.canadacentral.redis.azure.net
REDIS_PORT=10000
REDIS_PASSWORD=YOUR_REDIS_PRIMARY_KEY
REDIS_TLS=true
# Local Docker - uses port 6379, no password, no TLS
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# === CORS ===
ALLOWED_ORIGINS=https://zealous-mushroom-0aa6fa00f.1.azurestaticapps.net

# === EMAIL RATE LIMITING ===
MAX_EMAILS_PER_HOUR=200
WORKER_CONCURRENCY=5
MIN_DELAY_BETWEEN_EMAILS=2

# === SMTP ===
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=benedict52@ethereal.email
SMTP_PASS=d59PwvASMWTxyfBwmf

# === SERVER ===
PORT=8080
NODE_ENV=production
