# === DATABASE ===
# Azure: postgresql://username:password@server.postgres.database.azure.com/reachinbox?sslmode=require
# Local: postgresql://postgres:password@localhost:5433/reachinbox
DATABASE_URL=

# === REDIS ===
# Azure Cache for Redis: use port 6380 + TLS
# Local Docker: use port 6379, no password
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to "true" on Azure (Azure Redis requires TLS on port 6380)
REDIS_TLS=false

# === EMAIL RATE LIMITING ===
MAX_EMAILS_PER_HOUR=200
WORKER_CONCURRENCY=5
MIN_DELAY_BETWEEN_EMAILS=2

# === SMTP (Ethereal for dev, real SMTP for prod) ===
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# === SERVER PORT ===
PORT=8080
